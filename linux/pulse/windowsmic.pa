### Virtual mic for the Windows->Linux bridge.
### Drop in /etc/pulse/default.pa.d/windowsmic.pa
###
### Creates a null-sink that ffmpeg writes the incoming Windows stream into,
### then exposes its monitor as a remap-source named "WindowsMic" so apps see
### a regular input device. rate/channels/format MUST be explicit on the
### remap — defaults (44100Hz) silently produce no samples even though the
### source goes RUNNING.

load-module module-null-sink sink_name=virtmic rate=48000 channels=2 sink_properties=device.description=Virtual_Mic_Sink
load-module module-remap-source master=virtmic.monitor source_name=WindowsMic rate=48000 channels=2 format=s16le source_properties=device.description=WindowsMic
set-default-source WindowsMic
