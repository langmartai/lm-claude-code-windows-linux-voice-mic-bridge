# Copy to ~/.config/windowsmic-bridge/config.env and fill in.
# This file is sourced by both windowsmic-listen.sh and windowsmic-watchdog.sh.
# Do NOT commit this file with real values — the .env path is intentionally
# outside the repo so credentials never touch git.

# TCP port the listener accepts on (also what the Windows side connects to).
PORT=9999

# Windows host the watchdog SSHes into to kill hung ffmpeg processes.
# Format: user@host (or any value valid for `ssh <target>`).
# Leave empty to disable SSH-kill (watchdog will only restart the local
# listener; hung Windows ffmpeg has to be killed manually).
WIN_HOST=

# Path to the SSH private key used for the SSH-kill. The matching public key
# must be in authorized_keys on the Windows OpenSSH server.
WIN_KEY=

# Watchdog tuning (defaults shown).
# CHECK_INTERVAL=15      # seconds between source-level samples
# SILENT_LIMIT=3         # consecutive zero-peak samples before bouncing
# SAMPLE_SEC=3.0         # length of each sampling recording
# SKIP_HEAD_SEC=1.0      # parecord startup latency to skip
